# Copy this file to .env and fill in the credentials/flags needed for your local CLIs.
# .env is ignored by git.

# Required to opt in. These tests invoke real agent CLIs and may use paid model calls.
RUN_AGENT_SKILL_INTEGRATION_TESTS=0
AGENT_SKILL_CLI_TIMEOUT=900

# Auth keys or explicit "already logged in" markers.
# Leave provider keys blank if the CLI is already authenticated locally, then set
# the matching *_AUTH_READY value to 1.
OPENAI_API_KEY=
CODEX_SKILL_AUTH_READY=0

ANTHROPIC_API_KEY=
CLAUDE_SKILL_AUTH_READY=0

GH_TOKEN=
GITHUB_TOKEN=
COPILOT_SKILL_AUTH_READY=0

# Per-provider toggles. Set to 0 to skip a provider while running the others.
RUN_CODEX_SKILL_INTEGRATION=1
RUN_CLAUDE_SKILL_INTEGRATION=1
RUN_COPILOT_SKILL_INTEGRATION=1

# Command templates. The test runner expands:
# {workspace} {skill_dir} {subject_file} {report_path} {prompt_file} {scorer} {prompt}
#
# The defaults in the test file are suitable for common installations, but you can
# override them here if your CLI, auth, model, or permission flags differ.
CODEX_SKILL_COMMAND=codex exec --cd {workspace} --sandbox workspace-write --ask-for-approval never - < {prompt_file}
CLAUDE_SKILL_COMMAND=claude -p "$(cat {prompt_file})" --allowedTools Read Write "Bash(python3:*)" --permission-mode acceptEdits
COPILOT_SKILL_COMMAND=gh copilot -p "$(cat {prompt_file})" --allow-tool='read,write,shell(python3:*)'
